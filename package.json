{
  "name": "@illyism/transcribe",
  "version": "3.4.0",
  "description": "CLI tool to transcribe audio/video files to SRT format using OpenAI Whisper API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "transcribe": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm --external openai && bun build src/index.ts --outdir dist --target node --format esm --external openai && chmod +x dist/cli.js",
    "dev": "bun src/cli.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "transcribe",
    "whisper",
    "openai",
    "srt",
    "subtitles",
    "audio",
    "video",
    "speech-to-text",
    "cli"
  ],
  "author": "Ilias Ismanalijev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Illyism/transcribe-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Illyism/transcribe-cli/issues"
  },
  "homepage": "https://github.com/Illyism/transcribe-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "openai": "^4.0.0",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "ffmpeg": "*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/cli-progress": "^3.11.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
